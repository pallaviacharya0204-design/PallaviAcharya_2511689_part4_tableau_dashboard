      <aliases enabled='yes' />
      <column caption='Profit Margin' datatype='real' name='[Calculation_516506599687639041]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([profit])/SUM([sales])' />
      </column>
      <column caption='Cost' datatype='real' name='[Calculation_516506599687806978]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([sales])-SUM([profit])' />
      </column>
      <column caption='Average Order Value' datatype='real' name='[Calculation_516506599688036355]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([sales])/COUNTD([order_id])' />
      </column>
      <column caption='Return Rate' datatype='real' name='[Calculation_516506599688331268]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([return_flag])&#13;&#10;/&#13;&#10;COUNT([order_id])' />
      </column>
      <column caption='Shipping Delay Bucket' datatype='string' name='[Calculation_516506599689445381]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [delivery_days] &lt;= 2 THEN&#13;&#10;&quot;Fast&quot;&#13;&#10;&#13;&#10;ELSEIF [delivery_days] &lt;= 5 THEN&#13;&#10;&quot;Normal&quot;&#13;&#10;&#13;&#10;ELSE&#13;&#10;&quot;Delayed&quot;&#13;&#10;&#13;&#10;END' />
      </column>
